\
    // Auto-populate input with current date for easier testing\
    document.getElementById('dob').valueAsDate = new Date();\
\
    function addCalculatedDate(baseDate, record) \{\
        let target = new Date(baseDate);\
        if (record.offsetType === "days") \{\
            target.setDate(target.getDate() + record.offsetVal);\
        \} else if (record.offsetType === "weeks") \{\
            target.setDate(target.getDate() + (record.offsetVal * 7));\
        \} else if (record.offsetType === "months") \{\
            target.setMonth(target.getMonth() + record.offsetVal);\
        \} else if (record.offsetType === "years") \{\
            target.setFullYear(target.getFullYear() + record.offsetVal);\
        \} else if (record.offsetType === "yearsMonths") \{\
            target.setFullYear(target.getFullYear() + record.offsetVal.y);\
            target.setMonth(target.getMonth() + record.offsetVal.m);\
        \}\
        return target.toLocaleDateString('en-IN', \{ day: '2-digit', month: 'short', year: 'numeric' \});\
    \}\
\
    function generateSchedule() \{\
        const dobValue = document.getElementById('dob').value;\
        if (!dobValue) \{\
            alert("Please select a registration or Date of Birth.");\
            return;\
        \}\
\
        const baseDate = new Date(dobValue);\
        const gender = document.getElementById('gender').value;\
        const isJeEndemic = document.getElementById('jeEndemic').checked;\
        const outputDiv = document.getElementById('scheduleOutput');\
        outputDiv.innerHTML = "";\
\
        // Sort data dynamically into thematic arrays\
        const groups = \{\};\
\
        vaccinePayload.forEach(v => \{\
            // Evaluates App Filtering Rules Engine\
            if (v.condition === "je" && !isJeEndemic) return;\
            if (v.condition === "female" && gender !== "female") return;\
\
            if (!groups[v.group]) \{\
                groups[v.group] = [];\
            \}\
            groups[v.group].push(\{\
                ...v,\
                calculatedDate: addCalculatedDate(baseDate, v)\
            \});\
        \});\
\
        // DOM Rendering Engine\
        for (const [groupName, vaccines] of Object.entries(groups)) \{\
            const section = document.createElement('div');\
            section.className = 'timeline-section';\
            \
            const title = document.createElement('h2');\
            title.className = 'timeline-title';\
            title.innerText = groupName;\
            section.appendChild(title);\
\
            vaccines.forEach(vaccine => \{\
                const row = document.createElement('div');\
                row.className = 'vaccine-row';\
                row.id = `row-$\{vaccine.id\}`;\
\
                row.innerHTML = `\
                    <div class="flex-left">\
                        <input type="checkbox" class="status-checkbox" onchange="toggleComplete('$\{vaccine.id\}', this)">\
                        <div class="vaccine-details">\
                            <h4>$\{vaccine.name\}</h4>\
                            <div class="vaccine-meta">$\{vaccine.window\} \'95 $\{vaccine.route\}</div>\
                        </div>\
                    </div>\
                    <div class="date-badge">Due: $\{vaccine.calculatedDate\}</div>\
                `;\
                section.appendChild(row);\
            \});\
\
            outputDiv.appendChild(section);\
        \}\
    \}\
\
    function toggleComplete(id, checkbox) \{\
        const targetRow = document.getElementById(`row-$\{id\}`);\
        if (checkbox.checked) \{\
            targetRow.classList.add('completed');\
        \} else \{\
            targetRow.classList.remove('completed');\
        \}\
    \}\
</script>\
