        \{ id: "penta2", name: "Pentavalent - 2", window: "10 Weeks", offsetType: "weeks", offsetVal: 10, route: "Intra-muscular (Right thigh)", group: "Infant (Birth to 1 Year)" \},\
        \{ id: "opv2", name: "OPV - 2", window: "10 Weeks", offsetType: "weeks", offsetVal: 10, route: "Oral (2 drops)", group: "Infant (Birth to 1 Year)" \},\
        \{ id: "rvv2", name: "Rotavirus (RVV) - 2", window: "10 Weeks", offsetType: "weeks", offsetVal: 10, route: "Oral (5 drops)", group: "Infant (Birth to 1 Year)" \},\
\
        \{ id: "penta3", name: "Pentavalent - 3", window: "14 Weeks", offsetType: "weeks", offsetVal: 14, route: "Intra-muscular (Right thigh)", group: "Infant (Birth to 1 Year)" \},\
        \{ id: "opv3", name: "OPV - 3", window: "14 Weeks", offsetType: "weeks", offsetVal: 14, route: "Oral (2 drops)", group: "Infant (Birth to 1 Year)" \},\
        \{ id: "rvv3", name: "Rotavirus (RVV) - 3", window: "14 Weeks", offsetType: "weeks", offsetVal: 14, route: "Oral (5 drops)", group: "Infant (Birth to 1 Year)" \},\
        \{ id: "fipv2", name: "fIPV - 2", window: "14 Weeks", offsetType: "weeks", offsetVal: 14, route: "Intra-dermal (Right upper arm)", group: "Infant (Birth to 1 Year)" \},\
        \{ id: "pcv2", name: "PCV - 2", window: "14 Weeks", offsetType: "weeks", offsetVal: 14, route: "Intra-muscular (Left thigh)", group: "Infant (Birth to 1 Year)" \},\
