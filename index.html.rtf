        \{ id: "hpv2", name: "HPV Vaccine - Dose 2", window: "6 Months post Dose 1", offsetType: "yearsMonths", offsetVal: \{y: 9, m: 6\}, route: "Intra-muscular (Deltoid)", group: "Adolescent (2026 National Standard)", condition: "female" \},\
