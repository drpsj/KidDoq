        \{ id: "pcvBooster", name: "PCV - Booster", window: "9 Months", offsetType: "months", offsetVal: 9, route: "Intra-muscular (Right thigh)", group: "Infant (Birth to 1 Year)" \},\
        \{ id: "je1", name: "JE - 1 (Japanese Encephalitis)", window: "9 Months", offsetType: "months", offsetVal: 9, route: "Subcutaneous (Left upper arm)", group: "Infant (Birth to 1 Year)", condition: "je" \},\
